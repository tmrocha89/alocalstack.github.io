{
  "name": "alocalstack",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && node -e \"const fs=require('fs');const p='dist';fs.copyFileSync(p+'/index.html',p+'/404.html');console.log('404.html created for SPA fallback (GitHub Pages)')\"",
    "build:pages": "vite build && node -e \"const fs=require('fs');const p='dist';fs.copyFileSync(p+'/index.html',p+'/404.html');console.log('404.html created for SPA fallback (GitHub Pages)')\"",
    "preview": "vite preview",
    "lint": "echo 'Add eslint in a later pass'",
    "typecheck": "tsc -b",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-lambda": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sns": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@tanstack/react-query": "^5.60.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0",
    "sonner": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
